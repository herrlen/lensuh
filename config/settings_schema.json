[
  {
    "name": "theme_info",
    "theme_name": "LenSuh",
    "theme_version": "0.1.0",
    "theme_author": "herrlen",
    "theme_documentation_url": "https://github.com/herrlen/lensuh",
    "theme_support_url": "https://github.com/herrlen/lensuh/issues"
  },
  {
    "name": "t:settings_schema.colors.name",
    "settings": [
      {
        "type": "color",
        "id": "color_primary",
        "label": "t:settings_schema.colors.settings.primary.label",
        "default": "#1A1A1A"
      },
      {
        "type": "color",
        "id": "color_secondary",
        "label": "t:settings_schema.colors.settings.secondary.label",
        "default": "#F5F5F5"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "t:settings_schema.colors.settings.accent.label",
        "default": "#0055FF"
      },
      {
        "type": "color",
        "id": "color_background",
        "label": "t:settings_schema.colors.settings.background.label",
        "default": "#FFFFFF"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "t:settings_schema.colors.settings.text.label",
        "default": "#1A1A1A"
      }
    ]
  },
  {
    "name": "t:settings_schema.typography.name",
    "settings": [
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "t:settings_schema.typography.settings.font_heading.label",
        "default": "assistant_n4"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "t:settings_schema.typography.settings.font_body.label",
        "default": "assistant_n4"
      },
      {
        "type": "range",
        "id": "font_body_scale",
        "label": "t:settings_schema.typography.settings.font_body_scale.label",
        "min": 100,
        "max": 130,
        "step": 5,
        "default": 100,
        "unit": "%"
      }
    ]
  },
  {
    "name": "t:settings_schema.layout.name",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "label": "t:settings_schema.layout.settings.page_width.label",
        "min": 1000,
        "max": 1600,
        "step": 100,
        "default": 1200,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "spacing_sections",
        "label": "t:settings_schema.layout.settings.spacing_sections.label",
        "min": 0,
        "max": 100,
        "step": 4,
        "default": 40,
        "unit": "px"
      }
    ]
  },
  {
    "name": "t:settings_schema.seo.name",
    "settings": [
      {
        "type": "checkbox",
        "id": "seo_json_ld",
        "label": "t:settings_schema.seo.settings.json_ld.label",
        "info": "t:settings_schema.seo.settings.json_ld.info",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "seo_hreflang",
        "label": "t:settings_schema.seo.settings.hreflang.label",
        "info": "t:settings_schema.seo.settings.hreflang.info",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "seo_og_tags",
        "label": "t:settings_schema.seo.settings.og_tags.label",
        "default": true
      },
      {
        "type": "select",
        "id": "seo_robots_tags",
        "label": "t:settings_schema.seo.settings.robots_tags.label",
        "options": [
          { "value": "noindex", "label": "t:settings_schema.seo.settings.robots_tags.options.noindex" },
          { "value": "index", "label": "t:settings_schema.seo.settings.robots_tags.options.index" }
        ],
        "default": "noindex",
        "info": "t:settings_schema.seo.settings.robots_tags.info"
      }
    ]
  },
  {
    "name": "t:settings_schema.performance.name",
    "settings": [
      {
        "type": "checkbox",
        "id": "perf_lazy_loading",
        "label": "t:settings_schema.performance.settings.lazy_loading.label",
        "info": "t:settings_schema.performance.settings.lazy_loading.info",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "perf_preload_fonts",
        "label": "t:settings_schema.performance.settings.preload_fonts.label",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "perf_critical_css",
        "label": "t:settings_schema.performance.settings.critical_css.label",
        "info": "t:settings_schema.performance.settings.critical_css.info",
        "default": true
      }
    ]
  },
  {
    "name": "t:settings_schema.social.name",
    "settings": [
      {
        "type": "text",
        "id": "social_instagram_link",
        "label": "Instagram",
        "info": "t:settings_schema.social.settings.info"
      },
      {
        "type": "text",
        "id": "social_tiktok_link",
        "label": "TikTok"
      },
      {
        "type": "text",
        "id": "social_youtube_link",
        "label": "YouTube"
      },
      {
        "type": "text",
        "id": "social_facebook_link",
        "label": "Facebook"
      },
      {
        "type": "text",
        "id": "social_pinterest_link",
        "label": "Pinterest"
      }
    ]
  },
  {
    "name": "t:settings_schema.cart.name",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "t:settings_schema.cart.settings.cart_type.label",
        "options": [
          { "value": "drawer", "label": "t:settings_schema.cart.settings.cart_type.options.drawer" },
          { "value": "page", "label": "t:settings_schema.cart.settings.cart_type.options.page" }
        ],
        "default": "drawer"
      },
      {
        "type": "select",
        "id": "sticky_atc_mobile",
        "label": "t:settings_schema.cart.settings.sticky_atc_mobile.label",
        "options": [
          { "value": "disabled", "label": "t:settings_schema.cart.settings.sticky_atc_mobile.options.disabled" },
          { "value": "button", "label": "t:settings_schema.cart.settings.sticky_atc_mobile.options.button" },
          { "value": "full", "label": "t:settings_schema.cart.settings.sticky_atc_mobile.options.full" }
        ],
        "default": "full"
      },
      {
        "type": "checkbox",
        "id": "sticky_atc_desktop",
        "label": "t:settings_schema.cart.settings.sticky_atc_desktop.label",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "sticky_atc_buy_now",
        "label": "t:settings_schema.cart.settings.sticky_atc_buy_now.label",
        "default": false
      },
      {
        "type": "color",
        "id": "cart_drawer_bg",
        "label": "t:settings_schema.cart.settings.cart_drawer_bg.label",
        "default": "#FFFFFF"
      },
      {
        "type": "color",
        "id": "cart_drawer_text",
        "label": "t:settings_schema.cart.settings.cart_drawer_text.label",
        "default": "#1A1A1A"
      },
      {
        "type": "checkbox",
        "id": "quick_buy_enabled",
        "label": "t:settings_schema.cart.settings.quick_buy_enabled.label",
        "default": true
      },
      {
        "type": "select",
        "id": "quick_buy_style",
        "label": "t:settings_schema.cart.settings.quick_buy_style.label",
        "options": [
          { "value": "icon", "label": "t:settings_schema.cart.settings.quick_buy_style.options.icon" },
          { "value": "text", "label": "t:settings_schema.cart.settings.quick_buy_style.options.text" },
          { "value": "both", "label": "t:settings_schema.cart.settings.quick_buy_style.options.both" }
        ],
        "default": "both"
      },
      {
        "type": "header",
        "content": "t:settings_schema.cart.settings.free_shipping_header"
      },
      {
        "type": "checkbox",
        "id": "free_shipping_enabled",
        "label": "t:settings_schema.cart.settings.free_shipping_enabled.label",
        "default": false
      },
      {
        "type": "text",
        "id": "free_shipping_threshold",
        "label": "t:settings_schema.cart.settings.free_shipping_threshold.label",
        "info": "t:settings_schema.cart.settings.free_shipping_threshold.info",
        "default": "50"
      },
      {
        "type": "header",
        "content": "t:settings_schema.cart.settings.extras_header"
      },
      {
        "type": "checkbox",
        "id": "pre_order_enabled",
        "label": "t:settings_schema.cart.settings.pre_order_enabled.label",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "gift_wrapping_enabled",
        "label": "t:settings_schema.cart.settings.gift_wrapping_enabled.label",
        "default": false
      },
      {
        "type": "text",
        "id": "gift_wrapping_price",
        "label": "t:settings_schema.cart.settings.gift_wrapping_price.label",
        "info": "t:settings_schema.cart.settings.gift_wrapping_price.info",
        "default": "5"
      },
      {
        "type": "checkbox",
        "id": "in_store_pickup_enabled",
        "label": "t:settings_schema.cart.settings.in_store_pickup_enabled.label",
        "default": false
      }
    ]
  },
  {
    "name": "t:settings_schema.favicon.name",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "t:settings_schema.favicon.settings.image.label",
        "info": "t:settings_schema.favicon.settings.image.info"
      }
    ]
  }
]
