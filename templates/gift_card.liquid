{% layout none %}
<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ 'gift_cards.issued.title' | t }}</title>
  {{ 'base.css' | asset_url | stylesheet_tag }}
</head>
<body>
  <main class="gift-card" role="main">
    <div class="gift-card__inner">
      <header class="gift-card__header">
        <h1>{{ shop.name }}</h1>
        <h2>{{ 'gift_cards.issued.subtext' | t }}</h2>
        <p class="gift-card__price">{{ gift_card.initial_value | money }}</p>
      </header>

      <div class="gift-card__image-wrapper">
        <img src="{{ 'gift-card/card.jpg' | shopify_asset_url }}" alt="" height="auto" width="400" loading="lazy">
      </div>

      <div class="gift-card__code-wrapper">
        <input
          type="text"
          class="gift-card__code"
          value="{{ gift_card.code | format_code }}"
          aria-label="{{ 'gift_cards.issued.gift_card_code' | t }}"
          readonly
        >
      </div>

      <p>{{ 'gift_cards.issued.redeem_html' | t: value: gift_card.balance | money, shop_url: shop.url }}</p>

      {% if gift_card.pass_url %}
        <a href="{{ gift_card.pass_url }}" class="gift-card__apple-wallet">
          <img src="{{ 'gift-card/add-to-apple-wallet.svg' | shopify_asset_url }}" alt="{{ 'gift_cards.issued.add_to_apple_wallet' | t }}" width="120" height="40" loading="lazy">
        </a>
      {% endif %}

      <a href="{{ shop.url }}" class="gift-card__shop-link" target="_blank" rel="noopener">
        {{ 'gift_cards.issued.shop_link' | t }}
      </a>
    </div>
  </main>
</body>
</html>
