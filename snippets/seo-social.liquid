{%- comment -%}
  Open Graph + Twitter Card Meta Tags
  Include in layout/theme.liquid <head>
  {% render 'seo-social' %}
{%- endcomment -%}

{%- comment -%} — Open Graph — {%- endcomment -%}
<meta property="og:site_name" content="{{ shop.name | escape }}">
<meta property="og:url" content="{{ canonical_url }}">

{%- case template.name -%}
  {%- when 'product' -%}
    <meta property="og:type" content="product">
    <meta property="og:title" content="{{ product.title | escape }}">
    {%- if product.description != blank -%}
      <meta property="og:description" content="{{ product.description | strip_html | truncate: 200 | escape }}">
    {%- endif -%}
    {%- if product.featured_image -%}
      <meta property="og:image" content="https:{{ product.featured_image | image_url: width: 1200 }}">
      <meta property="og:image:width" content="1200">
      <meta property="og:image:alt" content="{{ product.featured_image.alt | default: product.title | escape }}">
    {%- endif -%}
    <meta property="product:price:amount" content="{{ product.price | money_without_currency | strip }}">
    <meta property="product:price:currency" content="{{ cart.currency.iso_code }}">
    {%- if product.available -%}
      <meta property="product:availability" content="in stock">
    {%- else -%}
      <meta property="product:availability" content="out of stock">
    {%- endif -%}

  {%- when 'article' -%}
    <meta property="og:type" content="article">
    <meta property="og:title" content="{{ article.title | escape }}">
    {%- if article.excerpt_or_content != blank -%}
      <meta property="og:description" content="{{ article.excerpt_or_content | strip_html | truncate: 200 | escape }}">
    {%- endif -%}
    {%- if article.image -%}
      <meta property="og:image" content="https:{{ article.image | image_url: width: 1200 }}">
      <meta property="og:image:width" content="1200">
      <meta property="og:image:alt" content="{{ article.image.alt | default: article.title | escape }}">
    {%- endif -%}
    <meta property="article:published_time" content="{{ article.published_at | date: '%Y-%m-%dT%H:%M:%S%z' }}">
    <meta property="article:author" content="{{ article.author }}">

  {%- when 'collection' -%}
    <meta property="og:type" content="website">
    <meta property="og:title" content="{{ collection.title | escape }}">
    {%- if collection.description != blank -%}
      <meta property="og:description" content="{{ collection.description | strip_html | truncate: 200 | escape }}">
    {%- endif -%}
    {%- if collection.image -%}
      <meta property="og:image" content="https:{{ collection.image | image_url: width: 1200 }}">
      <meta property="og:image:width" content="1200">
    {%- endif -%}

  {%- else -%}
    <meta property="og:type" content="website">
    <meta property="og:title" content="{{ page_title | escape }}">
    {%- if page_description != blank -%}
      <meta property="og:description" content="{{ page_description | escape }}">
    {%- endif -%}
    {%- if page_image -%}
      <meta property="og:image" content="https:{{ page_image | image_url: width: 1200 }}">
      <meta property="og:image:width" content="1200">
    {%- endif -%}
{%- endcase -%}

{%- comment -%} — Twitter Card — {%- endcomment -%}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ page_title | escape }}">
{%- if page_description != blank -%}
  <meta name="twitter:description" content="{{ page_description | truncate: 200 | escape }}">
{%- endif -%}
{%- if page_image -%}
  <meta name="twitter:image" content="https:{{ page_image | image_url: width: 1200 }}">
{%- endif -%}
