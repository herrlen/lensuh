{%- comment -%}
  Sticky Add-to-Cart for Desktop — Slim bar at top.
  Appears when regular ATC scrolls out of viewport.
  CLS = 0, includes optional Buy Now button.
  Usage: {% render 'sticky-atc-desktop', product: product %}
{%- endcomment -%}

{%- if product.available and settings.sticky_atc_desktop -%}
  <div
    class="sticky-atc-desktop"
    data-sticky-atc-desktop
    aria-hidden="true"
    role="complementary"
    aria-label="{{ 'cart.sticky_atc.label' | t }}"
  >
    <div class="sticky-atc-desktop__inner page-width">
      {%- if product.featured_image -%}
        <img
          src="{{ product.featured_image | image_url: width: 80 }}"
          alt="{{ product.title | escape }}"
          width="40"
          height="40"
          loading="lazy"
          class="sticky-atc-desktop__image"
        >
      {%- endif -%}

      <span class="sticky-atc-desktop__title">{{ product.title }}</span>
      <span class="sticky-atc-desktop__price" data-price-wrapper>{{ product.selected_or_first_available_variant.price | money }}</span>

      {%- unless product.has_only_default_variant -%}
        <select class="sticky-atc-desktop__variant" data-sticky-variant-select aria-label="{{ 'products.product.variant' | t }}">
          {%- for variant in product.variants -%}
            <option
              value="{{ variant.id }}"
              {% if variant == product.selected_or_first_available_variant %}selected{% endif %}
              {% unless variant.available %}disabled{% endunless %}
            >
              {{ variant.title }} — {{ variant.price | money }}
            </option>
          {%- endfor -%}
        </select>
      {%- endunless -%}

      <div class="sticky-atc-desktop__qty">
        <button type="button" class="sticky-atc-desktop__qty-btn" data-sticky-qty-minus aria-label="{{ 'cart.drawer.decrease' | t }}">−</button>
        <input type="number" value="1" min="1" class="sticky-atc-desktop__qty-input" data-sticky-qty-input aria-label="{{ 'products.product.quantity' | t }}">
        <button type="button" class="sticky-atc-desktop__qty-btn" data-sticky-qty-plus aria-label="{{ 'cart.drawer.increase' | t }}">+</button>
      </div>

      <button
        type="button"
        class="btn btn--primary sticky-atc-desktop__btn"
        data-sticky-atc-add
        data-variant-id="{{ product.selected_or_first_available_variant.id }}"
      >
        {{ 'products.product.add_to_cart' | t }}
      </button>

      {%- if settings.sticky_atc_buy_now -%}
        <button
          type="button"
          class="btn btn--outline sticky-atc-desktop__buy-now"
          data-sticky-buy-now
          data-variant-id="{{ product.selected_or_first_available_variant.id }}"
        >
          {{ 'cart.sticky_atc.buy_now' | t }}
        </button>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}
