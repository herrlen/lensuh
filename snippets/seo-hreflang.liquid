{%- comment -%}
  Hreflang Tags for International SEO
  Automatically renders hreflang for all published locales.
  Include in layout/theme.liquid <head>
  {% render 'seo-hreflang' %}
{%- endcomment -%}

{%- if shop.published_locales.size > 1 -%}
  {%- for locale in shop.published_locales -%}
    {%- if locale.primary -%}
      <link rel="alternate" hreflang="x-default" href="{{ canonical_url | replace: request.locale.root_url, locale.root_url }}">
    {%- endif -%}
    <link rel="alternate" hreflang="{{ locale.iso_code }}" href="{{ canonical_url | replace: request.locale.root_url, locale.root_url }}">
  {%- endfor -%}
{%- endif -%}
