{%- comment -%}
  JSON-LD Organization Schema (Schema.org)
  Renders on homepage only. Uses Theme Settings for data.
  Include in layout: {% render 'schema-organization' %}
{%- endcomment -%}

{%- if request.page_type == 'index' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": {{ shop.name | json }},
  "url": {{ request.origin | append: routes.root_url | json }},
  {%- if shop.brand.logo -%}
  "logo": {{ shop.brand.logo | image_url: width: 600 | prepend: 'https:' | json }},
  {%- endif -%}
  {%- if shop.description != blank -%}
  "description": {{ shop.description | json }},
  {%- endif -%}
  "sameAs": [
    {%- assign has_social = false -%}
    {%- if settings.social_instagram_link != blank -%}
      {%- if has_social -%},{%- endif -%}{{ settings.social_instagram_link | json }}
      {%- assign has_social = true -%}
    {%- endif -%}
    {%- if settings.social_tiktok_link != blank -%}
      {%- if has_social -%},{%- endif -%}{{ settings.social_tiktok_link | json }}
      {%- assign has_social = true -%}
    {%- endif -%}
    {%- if settings.social_youtube_link != blank -%}
      {%- if has_social -%},{%- endif -%}{{ settings.social_youtube_link | json }}
      {%- assign has_social = true -%}
    {%- endif -%}
    {%- if settings.social_facebook_link != blank -%}
      {%- if has_social -%},{%- endif -%}{{ settings.social_facebook_link | json }}
      {%- assign has_social = true -%}
    {%- endif -%}
    {%- if settings.social_pinterest_link != blank -%}
      {%- if has_social -%},{%- endif -%}{{ settings.social_pinterest_link | json }}
      {%- assign has_social = true -%}
    {%- endif -%}
  ]
}
</script>
{%- endif -%}
