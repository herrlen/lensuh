{%- comment -%}
  Trust Badges — configurable badge row for PDP or global use.
  Predefined icons + custom upload badges + payment method icons.
  Layout: Horizontal / Vertical, responsive.
  Usage: {% render 'trust-badges' %}
{%- endcomment -%}

{%- if settings.trust_badges_enabled -%}
  <div class="trust-badges trust-badges--{{ settings.trust_badges_layout | default: 'horizontal' }}">
    {%- comment -%} Predefined trust badges {%- endcomment -%}
    {%- if settings.trust_badge_secure_payment -%}
      <div class="trust-badges__item">
        <svg class="trust-badges__icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        <span class="trust-badges__text">{{ 'trust.secure_payment' | t }}</span>
      </div>
    {%- endif -%}

    {%- if settings.trust_badge_free_shipping -%}
      <div class="trust-badges__item">
        <svg class="trust-badges__icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        <span class="trust-badges__text">{{ 'trust.free_shipping' | t }}</span>
      </div>
    {%- endif -%}

    {%- if settings.trust_badge_money_back -%}
      <div class="trust-badges__item">
        <svg class="trust-badges__icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <span class="trust-badges__text">{{ 'trust.money_back' | t }}</span>
      </div>
    {%- endif -%}

    {%- if settings.trust_badge_fast_delivery -%}
      <div class="trust-badges__item">
        <svg class="trust-badges__icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <span class="trust-badges__text">{{ 'trust.fast_delivery' | t }}</span>
      </div>
    {%- endif -%}

    {%- if settings.trust_badge_ssl -%}
      <div class="trust-badges__item">
        <svg class="trust-badges__icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
        <span class="trust-badges__text">{{ 'trust.ssl' | t }}</span>
      </div>
    {%- endif -%}

    {%- if settings.trust_badge_made_in != blank -%}
      <div class="trust-badges__item">
        <svg class="trust-badges__icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        <span class="trust-badges__text">{{ 'trust.made_in' | t: country: settings.trust_badge_made_in }}</span>
      </div>
    {%- endif -%}

    {%- comment -%} Custom badge (uploaded icon + text) {%- endcomment -%}
    {%- if settings.trust_badge_custom_image != blank and settings.trust_badge_custom_text != blank -%}
      <div class="trust-badges__item">
        <img
          src="{{ settings.trust_badge_custom_image | image_url: width: 48 }}"
          alt=""
          width="24"
          height="24"
          loading="lazy"
          class="trust-badges__icon trust-badges__icon--custom"
        >
        <span class="trust-badges__text">{{ settings.trust_badge_custom_text }}</span>
      </div>
    {%- endif -%}

    {%- comment -%} Payment method icons {%- endcomment -%}
    {%- if settings.trust_show_payment_icons -%}
      <div class="trust-badges__payments">
        {%- for type in shop.enabled_payment_types -%}
          {{ type | payment_type_svg_tag: class: 'trust-badges__payment-icon' }}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
{%- endif -%}
