{%- comment -%}
  Renders pagination links.
  Usage: {% render 'pagination', paginate: paginate %}
{%- endcomment -%}

{%- if paginate.pages > 1 -%}
  <nav class="pagination" role="navigation" aria-label="{{ 'accessibility.navigation' | t }}">
    <ul class="pagination__list">
      {%- if paginate.previous -%}
        <li>
          <a href="{{ paginate.previous.url }}" aria-label="{{ 'accessibility.previous' | t }}">
            &laquo;
          </a>
        </li>
      {%- endif -%}

      {%- for part in paginate.parts -%}
        <li>
          {%- if part.is_link -%}
            <a href="{{ part.url }}">{{ part.title }}</a>
          {%- else -%}
            <span class="pagination__current" aria-current="page">{{ part.title }}</span>
          {%- endif -%}
        </li>
      {%- endfor -%}

      {%- if paginate.next -%}
        <li>
          <a href="{{ paginate.next.url }}" aria-label="{{ 'accessibility.next' | t }}">
            &raquo;
          </a>
        </li>
      {%- endif -%}
    </ul>
  </nav>
{%- endif -%}
