{%- comment -%}
  Shoppable Image with Hotspot Pins.
  Pins placed via Theme Editor blocks (x/y position + product).
  Click: Product tooltip with image, price, ATC.
  Mobile: Numbered pins, product list below.
{%- endcomment -%}

<section class="image-hotspots" data-section-id="{{ section.id }}" data-section-type="image-hotspots">
  <div class="image-hotspots__inner page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="image-hotspots__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="image-hotspots__container">
      <div class="image-hotspots__image-wrapper">
        {%- if section.settings.image != blank -%}
          {% render 'responsive-image',
            image: section.settings.image,
            max_width: 1200,
            sizes: '(min-width: 750px) 66vw, 100vw',
            class: 'image-hotspots__image'
          %}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}

        {%- for block in section.blocks -%}
          {%- if block.settings.product != blank -%}
            {%- assign pin_product = block.settings.product -%}
            <button
              type="button"
              class="image-hotspots__pin"
              style="left: {{ block.settings.x_position }}%; top: {{ block.settings.y_position }}%"
              data-hotspot-pin="{{ forloop.index }}"
              aria-label="{{ pin_product.title | escape }}"
              aria-expanded="false"
              {{ block.shopify_attributes }}
            >
              <span class="image-hotspots__pin-number">{{ forloop.index }}</span>
            </button>

            <div class="image-hotspots__tooltip" data-hotspot-tooltip="{{ forloop.index }}" aria-hidden="true">
              {%- if pin_product.featured_image -%}
                <img
                  src="{{ pin_product.featured_image | image_url: width: 200 }}"
                  alt="{{ pin_product.title | escape }}"
                  width="80"
                  height="80"
                  loading="lazy"
                  class="image-hotspots__tooltip-image"
                >
              {%- endif -%}
              <div class="image-hotspots__tooltip-info">
                <a href="{{ pin_product.url }}" class="image-hotspots__tooltip-title">{{ pin_product.title }}</a>
                <span class="image-hotspots__tooltip-price" data-price-wrapper>{{ pin_product.price | money }}</span>
                {%- if pin_product.available -%}
                  <button
                    type="button"
                    class="btn btn--primary image-hotspots__tooltip-atc"
                    data-quick-add
                    data-variant-id="{{ pin_product.first_available_variant.id }}"
                  >
                    {{ 'products.product.add_to_cart' | t }}
                  </button>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- comment -%} Mobile: Product list below image {%- endcomment -%}
      <div class="image-hotspots__mobile-list">
        {%- for block in section.blocks -%}
          {%- if block.settings.product != blank -%}
            {%- assign pin_product = block.settings.product -%}
            <a href="{{ pin_product.url }}" class="image-hotspots__mobile-item">
              <span class="image-hotspots__mobile-number">{{ forloop.index }}</span>
              {%- if pin_product.featured_image -%}
                <img
                  src="{{ pin_product.featured_image | image_url: width: 100 }}"
                  alt="{{ pin_product.title | escape }}"
                  width="50"
                  height="50"
                  loading="lazy"
                >
              {%- endif -%}
              <span class="image-hotspots__mobile-title">{{ pin_product.title }}</span>
              <span class="image-hotspots__mobile-price" data-price-wrapper>{{ pin_product.price | money }}</span>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.image_hotspots.name",
  "class": "section-image-hotspots",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.image_hotspots.settings.heading.label"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.image_hotspots.settings.image.label"
    }
  ],
  "blocks": [
    {
      "type": "hotspot_pin",
      "name": "t:sections.image_hotspots.blocks.pin.name",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "t:sections.image_hotspots.blocks.pin.settings.product.label"
        },
        {
          "type": "range",
          "id": "x_position",
          "label": "t:sections.image_hotspots.blocks.pin.settings.x_position.label",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50,
          "unit": "%"
        },
        {
          "type": "range",
          "id": "y_position",
          "label": "t:sections.image_hotspots.blocks.pin.settings.y_position.label",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50,
          "unit": "%"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.image_hotspots.presets.name"
    }
  ]
}
{% endschema %}
