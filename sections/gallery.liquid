<section class="gallery-section" data-section-id="{{ section.id }}" {% if section.settings.enabled == false %}hidden{% endif %}>
  <div class="gallery-section__inner page-width">
    {%- if section.settings.heading != blank -%}<h2 class="gallery-section__heading">{{ section.settings.heading }}</h2>{%- endif -%}
    <div class="gallery-section__grid gallery-section__grid--{{ section.settings.columns }}col">
      {%- for block in section.blocks -%}
        <div class="gallery-section__item" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {% render 'responsive-image', image: block.settings.image, max_width: 600, sizes: '(min-width: 750px) 33vw, 50vw', class: 'gallery-section__image' %}
          {%- endif -%}
          {%- if block.settings.caption != blank -%}<p class="gallery-section__caption">{{ block.settings.caption }}</p>{%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.gallery.name",
  "settings": [
    { "type": "checkbox", "id": "enabled", "label": "t:common.enabled", "default": true },
    { "type": "text", "id": "heading", "label": "t:common.heading" },
    { "type": "select", "id": "columns", "label": "t:common.columns", "options": [{"value":"2","label":"2"},{"value":"3","label":"3"},{"value":"4","label":"4"}], "default": "3" }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "t:sections.gallery.image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "t:common.image" },
        { "type": "text", "id": "caption", "label": "t:sections.gallery.caption" }
      ]
    }
  ],
  "presets": [{ "name": "t:sections.gallery.name" }]
}
{% endschema %}
