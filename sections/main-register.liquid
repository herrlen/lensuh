<section class="main-register" data-section-id="{{ section.id }}">
  <div class="main-register__inner page-width">
    <h1 class="main-register__title">{{ 'customer.register.title' | t }}</h1>

    {%- form 'create_customer' -%}
      {%- if form.errors -%}
        <div class="form-errors" role="alert">{{ form.errors | default_errors }}</div>
      {%- endif -%}

      <label for="register-first-name">{{ 'customer.register.first_name' | t }}</label>
      <input type="text" id="register-first-name" name="customer[first_name]" autocomplete="given-name">

      <label for="register-last-name">{{ 'customer.register.last_name' | t }}</label>
      <input type="text" id="register-last-name" name="customer[last_name]" autocomplete="family-name">

      <label for="register-email">{{ 'customer.register.email' | t }}</label>
      <input type="email" id="register-email" name="customer[email]" autocomplete="email" required>

      <label for="register-password">{{ 'customer.register.password' | t }}</label>
      <input type="password" id="register-password" name="customer[password]" autocomplete="new-password" required>

      <button type="submit" class="btn btn--primary">{{ 'customer.register.submit' | t }}</button>
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.main_register.name",
  "tag": "section"
}
{% endschema %}
