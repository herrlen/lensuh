<section class="collection-list" data-section-id="{{ section.id }}" {% if section.settings.enabled == false %}hidden{% endif %}>
  <div class="collection-list__inner page-width">
    {%- if section.settings.heading != blank -%}<h2 class="collection-list__heading">{{ section.settings.heading }}</h2>{%- endif -%}
    <div class="collection-list__grid">
      {%- for block in section.blocks -%}
        {%- if block.settings.collection != blank -%}
          {%- assign c = block.settings.collection -%}
          <a href="{{ c.url }}" class="collection-list__card" {{ block.shopify_attributes }}>
            {%- if c.image -%}
              {% render 'responsive-image', image: c.image, max_width: 600, sizes: '(min-width: 750px) 33vw, 50vw', class: 'collection-list__image' %}
            {%- endif -%}
            <h3 class="collection-list__title">{{ c.title }}</h3>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.collection_list.name",
  "settings": [
    { "type": "checkbox", "id": "enabled", "label": "t:common.enabled", "default": true },
    { "type": "text", "id": "heading", "label": "t:common.heading" }
  ],
  "blocks": [
    { "type": "collection", "name": "t:sections.collection_list.collection_block", "settings": [{ "type": "collection", "id": "collection", "label": "t:sections.collection_list.collection" }] }
  ],
  "presets": [{ "name": "t:sections.collection_list.name" }]
}
{% endschema %}
