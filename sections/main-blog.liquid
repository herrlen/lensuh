{%- render 'schema-breadcrumb' -%}

{%- paginate blog.articles by 12 -%}
<section class="main-blog" data-section-id="{{ section.id }}" data-section-type="blog">
  <div class="main-blog__inner page-width">
    <h1 class="main-blog__title">{{ blog.title }}</h1>

    <div class="main-blog__layout main-blog__layout--{{ section.settings.layout | default: 'grid' }}">
      <div class="main-blog__content">
        {%- if blog.articles.size > 0 -%}
          {%- comment -%} Featured post (first article, large) {%- endcomment -%}
          {%- if section.settings.show_featured and paginate.current_page == 1 -%}
            {%- assign featured = blog.articles.first -%}
            <article class="main-blog__featured">
              <a href="{{ featured.url }}" class="main-blog__featured-link">
                {%- if featured.image -%}
                  {% render 'responsive-image',
                    image: featured.image,
                    max_width: 1200,
                    sizes: '(min-width: 750px) 66vw, 100vw',
                    loading: 'eager',
                    class: 'main-blog__featured-image'
                  %}
                {%- endif -%}
                <div class="main-blog__featured-info">
                  <h2 class="main-blog__featured-title">{{ featured.title }}</h2>
                  <div class="main-blog__featured-meta">
                    <span class="main-blog__author">{{ featured.author }}</span>
                    <time datetime="{{ featured.published_at | date: '%Y-%m-%d' }}">
                      {{ featured.published_at | date: format: 'abbreviated_date' }}
                    </time>
                  </div>
                  {%- if featured.excerpt != blank -%}
                    <p class="main-blog__featured-excerpt">{{ featured.excerpt | strip_html | truncate: 250 }}</p>
                  {%- endif -%}
                </div>
              </a>
            </article>
          {%- endif -%}

          {%- comment -%} Article grid/list {%- endcomment -%}
          <div class="main-blog__grid" role="list">
            {%- for article in blog.articles -%}
              {%- if section.settings.show_featured and paginate.current_page == 1 and forloop.first -%}
                {%- continue -%}
              {%- endif -%}
              <article class="main-blog__article" role="listitem">
                <a href="{{ article.url }}" class="main-blog__card">
                  {%- if article.image -%}
                    {% render 'responsive-image',
                      image: article.image,
                      max_width: 600,
                      sizes: '(min-width: 990px) 33vw, 100vw'
                    %}
                  {%- endif -%}
                  <div class="main-blog__card-info">
                    <h2 class="main-blog__card-title">{{ article.title }}</h2>
                    <div class="main-blog__card-meta">
                      {%- if section.settings.show_author -%}
                        <span class="main-blog__author">{{ article.author }}</span>
                      {%- endif -%}
                      <time class="main-blog__card-date" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
                        {{ article.published_at | date: format: 'abbreviated_date' }}
                      </time>
                    </div>
                    {%- if article.excerpt != blank -%}
                      <p class="main-blog__card-excerpt">{{ article.excerpt | strip_html | truncate: 150 }}</p>
                    {%- endif -%}
                  </div>
                </a>
              </article>
            {%- endfor -%}
          </div>

          {%- if paginate.pages > 1 -%}
            {% render 'pagination', paginate: paginate %}
          {%- endif -%}
        {%- endif -%}
      </div>

      {%- comment -%} Sidebar {%- endcomment -%}
      {%- if section.settings.show_sidebar -%}
        <aside class="main-blog__sidebar">
          {%- comment -%} Search {%- endcomment -%}
          <div class="main-blog__sidebar-block">
            <h3 class="main-blog__sidebar-title">{{ 'search.title' | t }}</h3>
            <form action="{{ routes.search_url }}" method="get" role="search" class="main-blog__sidebar-search">
              <label for="blog-search" class="visually-hidden">{{ 'search.title' | t }}</label>
              <input type="search" id="blog-search" name="q" placeholder="{{ 'search.placeholder' | t }}" class="main-blog__sidebar-input">
              <input type="hidden" name="type" value="article">
            </form>
          </div>

          {%- comment -%} Categories / Tags {%- endcomment -%}
          {%- if blog.tags.size > 0 -%}
            <div class="main-blog__sidebar-block">
              <h3 class="main-blog__sidebar-title">{{ 'blog.sidebar.categories' | t }}</h3>
              <ul class="main-blog__tag-list">
                {%- for tag in blog.all_tags -%}
                  <li><a href="{{ blog.url }}/tagged/{{ tag | handleize }}">{{ tag }}</a></li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}

          {%- comment -%} Featured Posts {%- endcomment -%}
          {%- if blog.articles.size > 0 -%}
            <div class="main-blog__sidebar-block">
              <h3 class="main-blog__sidebar-title">{{ 'blog.sidebar.featured' | t }}</h3>
              <div class="main-blog__sidebar-featured">
                {%- for article in blog.articles limit: 3 -%}
                  <a href="{{ article.url }}" class="main-blog__sidebar-post">
                    {%- if article.image -%}
                      <img
                        src="{{ article.image | image_url: width: 120 }}"
                        alt="{{ article.title | escape }}"
                        width="60"
                        height="60"
                        loading="lazy"
                        class="main-blog__sidebar-post-image"
                      >
                    {%- endif -%}
                    <span class="main-blog__sidebar-post-title">{{ article.title | truncate: 50 }}</span>
                  </a>
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}
        </aside>
      {%- endif -%}
    </div>
  </div>
</section>
{%- endpaginate -%}

{% schema %}
{
  "name": "t:sections.main_blog.name",
  "tag": "section",
  "class": "section-main-blog",
  "settings": [
    { "type": "select", "id": "layout", "label": "t:sections.main_blog.settings.layout.label",
      "options": [
        { "value": "grid", "label": "t:sections.main_blog.settings.layout.options.grid" },
        { "value": "list", "label": "t:sections.main_blog.settings.layout.options.list" }
      ], "default": "grid" },
    { "type": "checkbox", "id": "show_featured", "label": "t:sections.main_blog.settings.show_featured.label", "default": true },
    { "type": "checkbox", "id": "show_author", "label": "t:sections.main_blog.settings.show_author.label", "default": true },
    { "type": "checkbox", "id": "show_sidebar", "label": "t:sections.main_blog.settings.show_sidebar.label", "default": true }
  ]
}
{% endschema %}
