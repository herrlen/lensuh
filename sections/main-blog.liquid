{%- render 'schema-breadcrumb' -%}

<section class="main-blog" data-section-id="{{ section.id }}" data-section-type="blog">
  <div class="main-blog__inner page-width">
    <h1 class="main-blog__title">{{ blog.title }}</h1>

    {%- if blog.articles.size > 0 -%}
      <div class="main-blog__grid" role="list">
        {%- for article in blog.articles -%}
          <article class="main-blog__article" role="listitem">
            <a href="{{ article.url }}" class="main-blog__card">
              {%- if article.image -%}
                {% render 'responsive-image',
                  image: article.image,
                  max_width: 600,
                  sizes: '(min-width: 990px) 33vw, 100vw'
                %}
              {%- endif -%}
              <div class="main-blog__card-info">
                <h2 class="main-blog__card-title">{{ article.title }}</h2>
                <time class="main-blog__card-date" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
                  {{ article.published_at | date: format: 'abbreviated_date' }}
                </time>
                {%- if article.excerpt != blank -%}
                  <p class="main-blog__card-excerpt">{{ article.excerpt | strip_html | truncate: 150 }}</p>
                {%- endif -%}
              </div>
            </a>
          </article>
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        {% render 'pagination', paginate: paginate %}
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.main_blog.name",
  "tag": "section",
  "class": "section-main-blog"
}
{% endschema %}
