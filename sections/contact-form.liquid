<section class="contact-form" data-section-id="{{ section.id }}" {% if section.settings.enabled == false %}hidden{% endif %}>
  <div class="contact-form__inner page-width">
    {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
    {%- form 'contact', class: 'contact-form__form' -%}
      {%- if form.posted_successfully? -%}
        <p class="contact-form__success" role="status">{{ 'contact.success' | t }}</p>
      {%- endif -%}
      {%- if form.errors -%}
        <div class="contact-form__errors" role="alert">{{ form.errors | default_errors }}</div>
      {%- endif -%}
      <label for="contact-name-{{ section.id }}">{{ 'contact.name' | t }}</label>
      <input type="text" id="contact-name-{{ section.id }}" name="contact[{{ 'contact.name' | t }}]" required>
      <label for="contact-email-{{ section.id }}">{{ 'contact.email' | t }}</label>
      <input type="email" id="contact-email-{{ section.id }}" name="contact[email]" required>
      <label for="contact-message-{{ section.id }}">{{ 'contact.message' | t }}</label>
      <textarea id="contact-message-{{ section.id }}" name="contact[body]" rows="5" required></textarea>
      <button type="submit" class="btn btn--primary">{{ 'contact.submit' | t }}</button>
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.contact_form.name",
  "settings": [
    { "type": "checkbox", "id": "enabled", "label": "t:common.enabled", "default": true },
    { "type": "text", "id": "heading", "label": "t:common.heading", "default": "Contact us" }
  ],
  "presets": [{ "name": "t:sections.contact_form.name" }]
}
{% endschema %}
