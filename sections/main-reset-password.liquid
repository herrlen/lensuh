<section class="main-reset" data-section-id="{{ section.id }}">
  <div class="main-reset__inner page-width">
    <h1 class="main-reset__title">{{ 'customer.reset_password.title' | t }}</h1>

    {%- form 'reset_customer_password' -%}
      <label for="reset-password">{{ 'customer.reset_password.password' | t }}</label>
      <input type="password" id="reset-password" name="customer[password]" autocomplete="new-password" required>

      <label for="reset-password-confirm">{{ 'customer.reset_password.confirm' | t }}</label>
      <input type="password" id="reset-password-confirm" name="customer[password_confirmation]" autocomplete="new-password" required>

      <button type="submit" class="btn btn--primary">{{ 'customer.reset_password.submit' | t }}</button>
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.main_reset_password.name",
  "tag": "section"
}
{% endschema %}
