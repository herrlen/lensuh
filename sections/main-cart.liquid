<section class="main-cart" data-section-id="{{ section.id }}" data-section-type="cart">
  <div class="main-cart__inner page-width">
    <h1 class="main-cart__title">{{ 'cart.general.title' | t }}</h1>

    {%- if cart.item_count > 0 -%}
      <form action="{{ routes.cart_url }}" method="post">
        <div class="main-cart__items" role="list">
          {%- for item in cart.items -%}
            <div class="main-cart__item" role="listitem" data-line-item="{{ item.key }}">
              <div class="main-cart__item-media">
                {%- if item.image -%}
                  {% render 'responsive-image',
                    image: item.image,
                    max_width: 150,
                    sizes: '150px'
                  %}
                {%- endif -%}
              </div>
              <div class="main-cart__item-info">
                <a href="{{ item.url }}">
                  <h2 class="main-cart__item-title">{{ item.product.title }}</h2>
                </a>
                {%- unless item.product.has_only_default_variant -%}
                  <p class="main-cart__item-variant">{{ item.variant.title }}</p>
                {%- endunless -%}
                <p class="main-cart__item-price" data-price-wrapper>{{ item.final_line_price | money }}</p>
              </div>
              <div class="main-cart__item-quantity">
                <label for="quantity-{{ item.key }}" class="visually-hidden">
                  {{ 'products.product.quantity' | t }}
                </label>
                <input
                  type="number"
                  id="quantity-{{ item.key }}"
                  name="updates[]"
                  value="{{ item.quantity }}"
                  min="0"
                  aria-label="{{ 'products.product.quantity' | t }}"
                >
              </div>
            </div>
          {%- endfor -%}
        </div>

        <div class="main-cart__footer">
          <p class="main-cart__subtotal">
            <span>{{ 'cart.general.subtotal' | t }}</span>
            <span data-price-wrapper>{{ cart.total_price | money }}</span>
          </p>
          <button type="submit" name="checkout" class="btn btn--primary">
            {{ 'cart.general.checkout' | t }}
          </button>
          <a href="{{ routes.all_products_collection_url }}" class="main-cart__continue">
            {{ 'cart.general.continue_shopping' | t }}
          </a>
        </div>
      </form>
    {%- else -%}
      <p>{{ 'cart.general.empty' | t }}</p>
      <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">
        {{ 'cart.general.continue_shopping' | t }}
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.main_cart.name",
  "tag": "section",
  "class": "section-main-cart"
}
{% endschema %}
