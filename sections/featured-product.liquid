<section class="featured-product" data-section-id="{{ section.id }}" {% if section.settings.enabled == false %}hidden{% endif %}>
  <div class="featured-product__inner page-width">
    {%- if section.settings.product != blank -%}
      {%- assign p = section.settings.product -%}
      <div class="featured-product__grid">
        <div class="featured-product__media">
          {%- if p.featured_image -%}
            {% render 'responsive-image', image: p.featured_image, max_width: 800, sizes: '(min-width: 750px) 50vw, 100vw', alt: p.title %}
          {%- endif -%}
        </div>
        <div class="featured-product__info">
          {%- if section.settings.heading != blank -%}
            <p class="featured-product__label">{{ section.settings.heading }}</p>
          {%- endif -%}
          <h2 class="featured-product__title">{{ p.title }}</h2>
          <p class="featured-product__price" data-price-wrapper>{{ p.price | money }}</p>
          {%- if p.description != blank -%}
            <div class="featured-product__description rte">{{ p.description | truncate: 300 }}</div>
          {%- endif -%}
          <a href="{{ p.url }}" class="btn btn--primary">{{ 'products.view_details' | t }}</a>
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.featured_product.name",
  "settings": [
    { "type": "checkbox", "id": "enabled", "label": "t:common.enabled", "default": true },
    { "type": "text", "id": "heading", "label": "t:common.heading", "default": "Featured" },
    { "type": "product", "id": "product", "label": "t:sections.featured_product.product" }
  ],
  "presets": [{ "name": "t:sections.featured_product.name" }]
}
{% endschema %}
