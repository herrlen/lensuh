<section class="banner-products" data-section-id="{{ section.id }}" {% if section.settings.enabled == false %}hidden{% endif %}>
  <div class="banner-products__banner">
    {%- if section.settings.image != blank -%}
      {% render 'responsive-image', image: section.settings.image, max_width: 1600, sizes: '100vw', class: 'banner-products__image' %}
    {%- endif -%}
    <div class="banner-products__banner-content page-width">
      {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <a {% if section.settings.button_link != blank %}href="{{ section.settings.button_link }}"{% endif %} class="btn btn--primary">{{ section.settings.button_label }}</a>
      {%- endif -%}
    </div>
  </div>
  <div class="banner-products__grid page-width">
    {%- for block in section.blocks -%}
      {%- if block.settings.product != blank -%}
        {%- assign bp = block.settings.product -%}
        <a href="{{ bp.url }}" class="banner-products__card" {{ block.shopify_attributes }}>
          {%- if bp.featured_image -%}
            {% render 'responsive-image', image: bp.featured_image, max_width: 400, sizes: '25vw', alt: bp.title %}
          {%- endif -%}
          <h3>{{ bp.title }}</h3>
          <p data-price-wrapper>{{ bp.price | money }}</p>
        </a>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.banner_products.name",
  "settings": [
    { "type": "checkbox", "id": "enabled", "label": "t:common.enabled", "default": true },
    { "type": "image_picker", "id": "image", "label": "t:common.image" },
    { "type": "text", "id": "heading", "label": "t:common.heading" },
    { "type": "text", "id": "button_label", "label": "t:common.button_label" },
    { "type": "url", "id": "button_link", "label": "t:common.button_link" }
  ],
  "blocks": [
    { "type": "product", "name": "t:sections.featured_product.product", "settings": [{ "type": "product", "id": "product", "label": "t:sections.featured_product.product" }] }
  ],
  "presets": [{ "name": "t:sections.banner_products.name" }]
}
{% endschema %}
