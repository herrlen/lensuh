<section class="hero-banner" data-section-id="{{ section.id }}" {% if section.settings.enabled == false %}hidden{% endif %}>
  {%- if section.settings.image != blank -%}
    {% render 'responsive-image', image: section.settings.image, max_width: 1600, sizes: '100vw', loading: 'eager', class: 'hero-banner__image' %}
  {%- endif -%}
  <div class="hero-banner__content page-width">
    {%- if section.settings.subheading != blank -%}<p class="hero-banner__subheading">{{ section.settings.subheading }}</p>{%- endif -%}
    {%- if section.settings.heading != blank -%}<h2 class="hero-banner__heading">{{ section.settings.heading }}</h2>{%- endif -%}
    {%- if section.settings.text != blank -%}<p class="hero-banner__text">{{ section.settings.text }}</p>{%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a {% if section.settings.button_link != blank %}href="{{ section.settings.button_link }}"{% endif %} class="btn btn--primary hero-banner__btn">{{ section.settings.button_label }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.hero_banner.name",
  "settings": [
    { "type": "checkbox", "id": "enabled", "label": "t:common.enabled", "default": true },
    { "type": "image_picker", "id": "image", "label": "t:common.image" },
    { "type": "text", "id": "subheading", "label": "t:common.subheading" },
    { "type": "text", "id": "heading", "label": "t:common.heading" },
    { "type": "textarea", "id": "text", "label": "t:common.text" },
    { "type": "text", "id": "button_label", "label": "t:common.button_label" },
    { "type": "url", "id": "button_link", "label": "t:common.button_link" }
  ],
  "presets": [{ "name": "t:sections.hero_banner.name" }]
}
{% endschema %}
