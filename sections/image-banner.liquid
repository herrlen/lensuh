<section class="image-banner" data-section-id="{{ section.id }}" data-section-type="image-banner">
  <div class="image-banner__inner{% unless section.settings.full_width %} page-width{% endunless %}">
    <div class="image-banner__media">
      {%- if section.settings.image != blank -%}
        {% render 'responsive-image',
          image: section.settings.image,
          max_width: 1600,
          sizes: '100vw',
          loading: 'eager',
          class: 'image-banner__image'
        %}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>

    <div class="image-banner__content">
      {%- if section.settings.heading != blank -%}
        <h1 class="image-banner__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <p class="image-banner__text">{{ section.settings.text }}</p>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <a
          {% if section.settings.button_link != blank %}href="{{ section.settings.button_link }}"{% endif %}
          class="btn btn--primary image-banner__btn"
        >
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.image_banner.name",
  "tag": "section",
  "class": "section-image-banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.image_banner.settings.image.label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.image_banner.settings.heading.label",
      "default": "Image banner"
    },
    {
      "type": "text",
      "id": "text",
      "label": "t:sections.image_banner.settings.text.label"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.image_banner.settings.button_label.label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.image_banner.settings.button_link.label"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "t:sections.image_banner.settings.full_width.label",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "t:sections.image_banner.presets.name"
    }
  ]
}
{% endschema %}
