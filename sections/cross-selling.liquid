{%- comment -%}
  Cross-Selling Section — "You might also like"
  Shopify Recommendations API, lazy-loaded, Quick-Buy.
{%- endcomment -%}

<section
  class="cross-selling"
  data-section-id="{{ section.id }}"
  data-section-type="cross-selling"
  data-lazy-section="cross-selling"
  data-product-id="{{ product.id }}"
  data-max-products="{{ section.settings.max_products | default: 4 }}"
  data-base-url="{{ routes.root_url }}"
>
  <div class="cross-selling__inner page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="cross-selling__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="cross-selling__grid" data-cross-selling-grid role="list" aria-live="polite">
      {%- comment -%} Populated by JS via Recommendations API {%- endcomment -%}
      {%- if recommendations.performed and recommendations.products_count > 0 -%}
        {%- for product in recommendations.products limit: section.settings.max_products -%}
          <div class="cross-selling__item" role="listitem">
            <a href="{{ product.url }}" class="cross-selling__card">
              <div class="cross-selling__card-media">
                {% render 'product-badges', product: product %}
                {%- if product.featured_image -%}
                  {% render 'responsive-image',
                    image: product.featured_image,
                    max_width: 400,
                    sizes: '(min-width: 990px) 25vw, (min-width: 750px) 33vw, 50vw',
                    alt: product.title
                  %}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
              <div class="cross-selling__card-info">
                <h3 class="cross-selling__card-title">{{ product.title }}</h3>
                <p class="cross-selling__card-price" data-price-wrapper>{{ product.price | money }}</p>
              </div>
            </a>
            {% render 'quick-buy-button', product: product %}
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.cross_selling.name",
  "class": "section-cross-selling",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.cross_selling.settings.heading.label",
      "default": "You might also like"
    },
    {
      "type": "select",
      "id": "max_products",
      "label": "t:sections.cross_selling.settings.max_products.label",
      "options": [
        { "value": "4", "label": "4" },
        { "value": "6", "label": "6" },
        { "value": "8", "label": "8" }
      ],
      "default": "4"
    }
  ],
  "presets": [
    {
      "name": "t:sections.cross_selling.presets.name"
    }
  ]
}
{% endschema %}
