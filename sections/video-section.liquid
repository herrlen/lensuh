<section class="video-section-wrap" data-section-id="{{ section.id }}" {% if section.settings.enabled == false %}hidden{% endif %}>
  <div class="video-section-wrap__inner page-width">
    {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
    {% render 'product-video', video_url: section.settings.video_url, poster: section.settings.poster, aspect: section.settings.aspect %}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.video.name",
  "settings": [
    { "type": "checkbox", "id": "enabled", "label": "t:common.enabled", "default": true },
    { "type": "text", "id": "heading", "label": "t:common.heading" },
    { "type": "text", "id": "video_url", "label": "t:sections.video.video_url" },
    { "type": "image_picker", "id": "poster", "label": "t:sections.video.poster" },
    { "type": "select", "id": "aspect", "label": "t:sections.video.aspect", "options": [{"value":"16-9","label":"16:9"},{"value":"4-3","label":"4:3"},{"value":"1-1","label":"1:1"}], "default": "16-9" }
  ],
  "presets": [{ "name": "t:sections.video.name" }]
}
{% endschema %}
