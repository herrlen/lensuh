{%- comment -%}
  Split-Screen — 50/50 Layout: Video | Text/CTA or Video | Products.
  Responsive: stacked on mobile.
{%- endcomment -%}

<section class="split-screen" data-section-id="{{ section.id }}">
  <div class="split-screen__inner{% unless section.settings.full_width %} page-width{% endunless %}">
    <div class="split-screen__grid{% if section.settings.reverse %} split-screen__grid--reverse{% endif %}">
      {%- comment -%} Video side {%- endcomment -%}
      <div class="split-screen__media">
        {%- if section.settings.video_url != blank -%}
          {% render 'product-video',
            video_url: section.settings.video_url,
            poster: section.settings.image,
            aspect: '16:9'
          %}
        {%- elsif section.settings.image != blank -%}
          {% render 'responsive-image',
            image: section.settings.image,
            max_width: 800,
            sizes: '(min-width: 750px) 50vw, 100vw',
            class: 'split-screen__image'
          %}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>

      {%- comment -%} Content side {%- endcomment -%}
      <div class="split-screen__content">
        {%- if section.settings.heading != blank -%}
          <h2 class="split-screen__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.text != blank -%}
          <div class="split-screen__text rte">{{ section.settings.text }}</div>
        {%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <a
            {% if section.settings.button_link != blank %}href="{{ section.settings.button_link }}"{% endif %}
            class="btn btn--primary split-screen__btn"
          >
            {{ section.settings.button_label }}
          </a>
        {%- endif -%}

        {%- comment -%} Optional: Product blocks {%- endcomment -%}
        {%- if section.blocks.size > 0 -%}
          <div class="split-screen__products">
            {%- for block in section.blocks -%}
              {%- if block.settings.product != blank -%}
                {%- assign sp = block.settings.product -%}
                <a href="{{ sp.url }}" class="split-screen__product-card" {{ block.shopify_attributes }}>
                  {%- if sp.featured_image -%}
                    <img
                      src="{{ sp.featured_image | image_url: width: 200 }}"
                      alt="{{ sp.title | escape }}"
                      width="80"
                      height="80"
                      loading="lazy"
                      class="split-screen__product-image"
                    >
                  {%- endif -%}
                  <div class="split-screen__product-info">
                    <span class="split-screen__product-title">{{ sp.title }}</span>
                    <span class="split-screen__product-price" data-price-wrapper>{{ sp.price | money }}</span>
                  </div>
                </a>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.split_screen.name",
  "class": "section-split-screen",
  "settings": [
    { "type": "text", "id": "video_url", "label": "t:sections.split_screen.settings.video_url.label" },
    { "type": "image_picker", "id": "image", "label": "t:sections.split_screen.settings.image.label" },
    { "type": "text", "id": "heading", "label": "t:sections.split_screen.settings.heading.label" },
    { "type": "richtext", "id": "text", "label": "t:sections.split_screen.settings.text.label" },
    { "type": "text", "id": "button_label", "label": "t:sections.split_screen.settings.button_label.label" },
    { "type": "url", "id": "button_link", "label": "t:sections.split_screen.settings.button_link.label" },
    { "type": "checkbox", "id": "reverse", "label": "t:sections.split_screen.settings.reverse.label", "default": false },
    { "type": "checkbox", "id": "full_width", "label": "t:sections.split_screen.settings.full_width.label", "default": false }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "t:sections.split_screen.blocks.product.name",
      "settings": [
        { "type": "product", "id": "product", "label": "t:sections.split_screen.blocks.product.settings.product.label" }
      ]
    }
  ],
  "presets": [{ "name": "t:sections.split_screen.presets.name" }]
}
{% endschema %}
