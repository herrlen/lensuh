<section class="recently-viewed" data-section-id="{{ section.id }}" data-section-type="recently-viewed" {% if section.settings.enabled == false %}hidden{% endif %}>
  <div class="recently-viewed__inner page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="recently-viewed__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    <div class="recently-viewed__grid" data-recently-viewed-grid aria-live="polite">
      {%- comment -%} Populated by JS from localStorage {%- endcomment -%}
    </div>
    <p class="recently-viewed__empty" data-recently-viewed-empty>{{ 'recently_viewed.empty' | t }}</p>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.recently_viewed.name",
  "settings": [
    { "type": "checkbox", "id": "enabled", "label": "t:common.enabled", "default": true },
    { "type": "text", "id": "heading", "label": "t:common.heading", "default": "Recently viewed" }
  ],
  "presets": [{ "name": "t:sections.recently_viewed.name" }]
}
{% endschema %}
