<section class="rich-text" data-section-id="{{ section.id }}" {% if section.settings.enabled == false %}hidden{% endif %}>
  <div class="rich-text__inner page-width rich-text__content--{{ section.settings.alignment }}">
    {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
    {%- if section.settings.content != blank -%}<div class="rte">{{ section.settings.content }}</div>{%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a {% if section.settings.button_link != blank %}href="{{ section.settings.button_link }}"{% endif %} class="btn btn--primary">{{ section.settings.button_label }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.rich_text.name",
  "settings": [
    { "type": "checkbox", "id": "enabled", "label": "t:common.enabled", "default": true },
    { "type": "text", "id": "heading", "label": "t:common.heading" },
    { "type": "richtext", "id": "content", "label": "t:sections.collapsible.content" },
    { "type": "select", "id": "alignment", "label": "t:common.alignment", "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"},{"value":"right","label":"Right"}], "default": "center" },
    { "type": "text", "id": "button_label", "label": "t:common.button_label" },
    { "type": "url", "id": "button_link", "label": "t:common.button_link" }
  ],
  "presets": [{ "name": "t:sections.rich_text.name" }]
}
{% endschema %}
