<section class="main-password" data-section-id="{{ section.id }}">
  <div class="main-password__inner page-width">
    <h1 class="main-password__title">{{ shop.name }}</h1>
    <p class="main-password__text">{{ 'general.password.title' | t }}</p>

    {%- form 'storefront_password' -%}
      <label for="password-{{ section.id }}">{{ 'general.password.label' | t }}</label>
      <input type="password" id="password-{{ section.id }}" name="password" placeholder="{{ 'general.password.placeholder' | t }}">
      <button type="submit" class="btn btn--primary">{{ 'general.password.submit' | t }}</button>
      {%- if form.errors -%}
        <p class="main-password__error" role="alert">{{ form.errors.messages.password }}</p>
      {%- endif -%}
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.main_password.name",
  "tag": "section",
  "class": "section-main-password"
}
{% endschema %}
