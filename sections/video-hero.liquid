{%- comment -%}
  Video Hero — Fullwidth video with text overlay.
  Autoplay: muted only. Poster image fallback.
  Mobile: optional static image instead of video.
{%- endcomment -%}

<section class="video-hero" data-section-id="{{ section.id }}" data-section-type="video-hero">
  <div class="video-hero__media">
    {%- if section.settings.video_url != blank -%}
      <div class="video-hero__video-wrapper" data-video-hero-wrapper>
        {%- comment -%} Poster as fallback + mobile static {%- endcomment -%}
        {%- if section.settings.poster_image != blank -%}
          <img
            src="{{ section.settings.poster_image | image_url: width: 1600 }}"
            alt=""
            width="1600"
            height="900"
            loading="eager"
            class="video-hero__poster{% unless section.settings.mobile_static %} video-hero__poster--desktop-only{% endunless %}"
          >
        {%- endif -%}

        {%- comment -%} Video: loaded via JS facade or directly {%- endcomment -%}
        <video
          class="video-hero__video"
          autoplay
          muted
          loop
          playsinline
          data-video-hero
          {%- if section.settings.poster_image != blank %}
            poster="{{ section.settings.poster_image | image_url: width: 1600 }}"
          {%- endif %}
        >
          {%- if section.settings.video_url != blank -%}
            <source src="{{ section.settings.video_url }}" type="video/mp4">
          {%- endif -%}
        </video>
      </div>
    {%- elsif section.settings.poster_image != blank -%}
      {% render 'responsive-image',
        image: section.settings.poster_image,
        max_width: 1600,
        sizes: '100vw',
        loading: 'eager',
        class: 'video-hero__poster-image'
      %}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}

    {%- if section.settings.overlay_opacity > 0 -%}
      <div class="video-hero__overlay" style="background-color: {{ section.settings.overlay_color }};opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }}"></div>
    {%- endif -%}
  </div>

  <div class="video-hero__content page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="video-hero__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.text != blank -%}
      <p class="video-hero__text">{{ section.settings.text }}</p>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a
        {% if section.settings.button_link != blank %}href="{{ section.settings.button_link }}"{% endif %}
        class="btn btn--primary video-hero__btn"
      >
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.video_hero.name",
  "class": "section-video-hero",
  "settings": [
    { "type": "text", "id": "video_url", "label": "t:sections.video_hero.settings.video_url.label", "info": "t:sections.video_hero.settings.video_url.info" },
    { "type": "image_picker", "id": "poster_image", "label": "t:sections.video_hero.settings.poster_image.label" },
    { "type": "checkbox", "id": "mobile_static", "label": "t:sections.video_hero.settings.mobile_static.label", "info": "t:sections.video_hero.settings.mobile_static.info", "default": true },
    { "type": "text", "id": "heading", "label": "t:sections.video_hero.settings.heading.label" },
    { "type": "text", "id": "text", "label": "t:sections.video_hero.settings.text.label" },
    { "type": "text", "id": "button_label", "label": "t:sections.video_hero.settings.button_label.label" },
    { "type": "url", "id": "button_link", "label": "t:sections.video_hero.settings.button_link.label" },
    { "type": "color", "id": "overlay_color", "label": "t:sections.video_hero.settings.overlay_color.label", "default": "#000000" },
    { "type": "range", "id": "overlay_opacity", "label": "t:sections.video_hero.settings.overlay_opacity.label", "min": 0, "max": 90, "step": 5, "default": 30, "unit": "%" }
  ],
  "presets": [{ "name": "t:sections.video_hero.presets.name" }]
}
{% endschema %}
