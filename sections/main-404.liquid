<section class="main-404" data-section-id="{{ section.id }}">
  <div class="main-404__inner page-width">
    <h1 class="main-404__title">{{ 'general.404.title' | t }}</h1>
    <p class="main-404__text">{{ 'general.404.text' | t }}</p>
    <a href="{{ routes.root_url }}" class="btn btn--primary">
      {{ 'general.404.link' | t }}
    </a>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.main_404.name",
  "tag": "section",
  "class": "section-main-404"
}
{% endschema %}
