<section class="main-account" data-section-id="{{ section.id }}">
  <div class="main-account__inner page-width">
    <h1 class="main-account__title">{{ 'customer.account.title' | t }}</h1>
    <p>{{ 'customer.account.welcome' | t: name: customer.first_name }}</p>
    <a href="{{ routes.account_logout_url }}">{{ 'customer.account.logout' | t }}</a>

    <h2>{{ 'customer.orders.title' | t }}</h2>
    {%- if customer.orders.size > 0 -%}
      <table class="main-account__orders">
        <thead>
          <tr>
            <th>{{ 'customer.orders.order_number' | t }}</th>
            <th>{{ 'customer.orders.date' | t }}</th>
            <th>{{ 'customer.orders.total' | t }}</th>
            <th>{{ 'customer.orders.status' | t }}</th>
          </tr>
        </thead>
        <tbody>
          {%- for order in customer.orders -%}
            <tr>
              <td><a href="{{ order.customer_url }}">{{ order.name }}</a></td>
              <td>{{ order.created_at | date: format: 'abbreviated_date' }}</td>
              <td>{{ order.total_net_amount | money }}</td>
              <td>{{ order.fulfillment_status_label }}</td>
            </tr>
          {%- endfor -%}
        </tbody>
      </table>
    {%- else -%}
      <p>{{ 'customer.orders.none' | t }}</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.main_account.name",
  "tag": "section"
}
{% endschema %}
