<section class="map-section" data-section-id="{{ section.id }}" {% if section.settings.enabled == false %}hidden{% endif %}>
  <div class="map-section__inner page-width">
    {%- if section.settings.heading != blank -%}<h2 class="map-section__heading">{{ section.settings.heading }}</h2>{%- endif -%}
    {%- if section.settings.address != blank -%}
      <div class="map-section__embed">
        <iframe
          src="https://www.google.com/maps?q={{ section.settings.address | url_encode }}&output=embed"
          width="100%"
          height="450"
          loading="lazy"
          title="{{ 'map.title' | t }}"
        ></iframe>
      </div>
      <p class="map-section__address">{{ section.settings.address }}</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.map.name",
  "settings": [
    { "type": "checkbox", "id": "enabled", "label": "t:common.enabled", "default": true },
    { "type": "text", "id": "heading", "label": "t:common.heading" },
    { "type": "text", "id": "address", "label": "t:sections.map.address", "info": "t:sections.map.address_info" }
  ],
  "presets": [{ "name": "t:sections.map.name" }]
}
{% endschema %}
