{%- comment -%}
  FAQ Accordion — with Schema.org FAQPage markup.
  Blocks: faq_item (question, answer). Keyboard accessible.
{%- endcomment -%}

{%- render 'schema-faq', blocks: section.blocks -%}

<section class="faq-section" data-section-id="{{ section.id }}">
  <div class="faq-section__inner page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="faq-section__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="faq-section__list" role="list">
        {%- for block in section.blocks -%}
          {%- if block.settings.question != blank -%}
            <div class="faq-section__item" role="listitem" {{ block.shopify_attributes }}>
              <button
                type="button"
                class="faq-section__question"
                aria-expanded="false"
                aria-controls="faq-answer-{{ block.id }}"
                data-faq-toggle
              >
                <span>{{ block.settings.question }}</span>
                {% render 'icon', icon: 'chevron-down' %}
              </button>
              <div
                id="faq-answer-{{ block.id }}"
                class="faq-section__answer"
                role="region"
                hidden
              >
                <div class="rte">{{ block.settings.answer }}</div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.faq_section.name",
  "class": "section-faq",
  "settings": [
    { "type": "text", "id": "heading", "label": "t:sections.faq_section.settings.heading.label", "default": "FAQ" }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "t:sections.faq_section.blocks.faq_item.name",
      "settings": [
        { "type": "text", "id": "question", "label": "t:sections.faq_section.blocks.faq_item.settings.question.label" },
        { "type": "richtext", "id": "answer", "label": "t:sections.faq_section.blocks.faq_item.settings.answer.label" }
      ]
    }
  ],
  "presets": [{ "name": "t:sections.faq_section.presets.name" }]
}
{% endschema %}
