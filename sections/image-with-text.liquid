<section class="image-with-text" data-section-id="{{ section.id }}" {% if section.settings.enabled == false %}hidden{% endif %}>
  <div class="image-with-text__inner page-width">
    <div class="image-with-text__grid image-with-text__grid--{{ section.settings.image_position }}">
      <div class="image-with-text__media">
        {%- if section.settings.image != blank -%}
          {% render 'responsive-image', image: section.settings.image, max_width: 800, sizes: '(min-width: 750px) 50vw, 100vw', class: 'image-with-text__image' %}
        {%- endif -%}
      </div>
      <div class="image-with-text__content">
        {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
        {%- if section.settings.text != blank -%}<div class="rte">{{ section.settings.text }}</div>{%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <a {% if section.settings.button_link != blank %}href="{{ section.settings.button_link }}"{% endif %} class="btn btn--primary">{{ section.settings.button_label }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.image_with_text.name",
  "settings": [
    { "type": "checkbox", "id": "enabled", "label": "t:common.enabled", "default": true },
    { "type": "image_picker", "id": "image", "label": "t:common.image" },
    { "type": "select", "id": "image_position", "label": "t:sections.image_with_text.image_position", "options": [{"value":"left","label":"Left"},{"value":"right","label":"Right"}], "default": "left" },
    { "type": "text", "id": "heading", "label": "t:common.heading" },
    { "type": "richtext", "id": "text", "label": "t:common.text" },
    { "type": "text", "id": "button_label", "label": "t:common.button_label" },
    { "type": "url", "id": "button_link", "label": "t:common.button_link" }
  ],
  "presets": [{ "name": "t:sections.image_with_text.name" }]
}
{% endschema %}
