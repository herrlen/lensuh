<section class="newsletter" data-section-id="{{ section.id }}" {% if section.settings.enabled == false %}hidden{% endif %}>
  <div class="newsletter__inner page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="newsletter__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.text != blank -%}
      <p class="newsletter__text">{{ section.settings.text }}</p>
    {%- endif -%}
    {%- form 'customer', class: 'newsletter__form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <label for="newsletter-email-{{ section.id }}" class="visually-hidden">{{ 'newsletter.email' | t }}</label>
      <input
        type="email"
        id="newsletter-email-{{ section.id }}"
        name="contact[email]"
        placeholder="{{ 'newsletter.placeholder' | t }}"
        class="newsletter__input"
        required
      >
      <button type="submit" class="btn btn--primary newsletter__submit">
        {{ 'newsletter.submit' | t }}
      </button>
      {%- if form.posted_successfully? -%}
        <p class="newsletter__success" role="status">{{ 'newsletter.success' | t }}</p>
      {%- endif -%}
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.newsletter.name",
  "settings": [
    { "type": "checkbox", "id": "enabled", "label": "t:common.enabled", "default": true },
    { "type": "text", "id": "heading", "label": "t:common.heading", "default": "Subscribe" },
    { "type": "textarea", "id": "text", "label": "t:common.text" }
  ],
  "presets": [{ "name": "t:sections.newsletter.name" }]
}
{% endschema %}
