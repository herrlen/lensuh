<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}" {% if request.locale.iso_code == 'ar' or request.locale.iso_code == 'he' %}dir="rtl"{% endif %}>
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, height=device-height, minimum-scale=1.0">

  {% comment %} SEO: Title + Meta + Canonical + Robots {% endcomment %}
  {%- render 'seo-meta' -%}

  {% comment %} SEO: Hreflang (International) {% endcomment %}
  {%- render 'seo-hreflang' -%}

  {% comment %} SEO: Open Graph + Twitter Cards {% endcomment %}
  {%- render 'seo-social' -%}

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  {% comment %} Preconnect {% endcomment %}
  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
  <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>

  {% comment %} Font Faces — swap, Shopify CDN {% endcomment %}
  {%- render 'font-face' -%}

  {% comment %} Critical CSS — inline above-the-fold styles {% endcomment %}
  {%- render 'critical-css' -%}

  {% comment %} Main CSS — async loaded {% endcomment %}
  <link rel="preload" href="{{ 'base.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript>{{ 'base.css' | asset_url | stylesheet_tag }}</noscript>

  {% comment %} Preload LCP font {% endcomment %}
  {%- assign heading_font_url = settings.font_heading | font_url -%}
  {%- if heading_font_url != blank -%}
    <link rel="preload" href="{{ heading_font_url }}" as="font" type="font/woff2" crossorigin>
  {%- endif -%}

  {% comment %} Structured Data {% endcomment %}
  {%- render 'schema-organization' -%}

  {{ content_for_header }}

  {%- render 'theme-strings' -%}
</head>

<body class="template-{{ template.name }}{% if template.suffix %} template-{{ template.name }}-{{ template.suffix }}{% endif %}">
  <a class="skip-to-content-link visually-hidden" href="#MainContent">
    {{ 'accessibility.skip_to_content' | t }}
  </a>

  {% sections 'header-group' %}

  {% render 'breadcrumbs' %}

  <main id="MainContent" class="main-content" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {% sections 'footer-group' %}

  {% comment %} Cart Drawer {% endcomment %}
  {% section 'cart-drawer' %}

  {% render 'toast-notification' %}

  {% comment %} Cart Drawer + Navigation CSS (async) {% endcomment %}
  <link rel="preload" href="{{ 'cart-drawer.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="{{ 'cart-drawer.css' | asset_url }}"></noscript>
  <link rel="preload" href="{{ 'navigation.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="{{ 'navigation.css' | asset_url }}"></noscript>
  <link rel="preload" href="{{ 'collection-filters.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="{{ 'collection-filters.css' | asset_url }}"></noscript>
  <link rel="preload" href="{{ 'trust-badges.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="{{ 'trust-badges.css' | asset_url }}"></noscript>
  <link rel="preload" href="{{ 'promotions.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="{{ 'promotions.css' | asset_url }}"></noscript>
  <link rel="preload" href="{{ 'pdp-features.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="{{ 'pdp-features.css' | asset_url }}"></noscript>
  <link rel="preload" href="{{ 'visual-merch.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="{{ 'visual-merch.css' | asset_url }}"></noscript>
  <link rel="preload" href="{{ 'video.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="{{ 'video.css' | asset_url }}"></noscript>
  <link rel="preload" href="{{ 'content.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="{{ 'content.css' | asset_url }}"></noscript>
  {%- if request.locale.iso_code == 'ar' or request.locale.iso_code == 'he' -%}
    <link rel="stylesheet" href="{{ 'rtl.css' | asset_url }}">
  {%- endif -%}

  {% comment %} Theme JS {% endcomment %}
  <script src="{{ 'theme.js' | asset_url }}" defer></script>
  <script src="{{ 'cart-drawer.js' | asset_url }}" defer></script>
  <script src="{{ 'cart-atc.js' | asset_url }}" defer></script>
  <script src="{{ 'free-shipping-bar.js' | asset_url }}" defer></script>
  <script src="{{ 'in-store-pickup.js' | asset_url }}" defer></script>
  <script src="{{ 'mega-menu.js' | asset_url }}" defer></script>
  <script src="{{ 'predictive-search.js' | asset_url }}" defer></script>
  <script src="{{ 'collection-filters.js' | asset_url }}" defer></script>
  <script src="{{ 'sticky-header.js' | asset_url }}" defer></script>
  <script src="{{ 'announcement-bar.js' | asset_url }}" defer></script>
  <script src="{{ 'countdown-timer.js' | asset_url }}" defer></script>
  <script src="{{ 'cross-selling.js' | asset_url }}" defer></script>
  <script src="{{ 'back-in-stock.js' | asset_url }}" defer></script>
  <script src="{{ 'product-tabs.js' | asset_url }}" defer></script>
  <script src="{{ 'size-chart.js' | asset_url }}" defer></script>
  <script src="{{ 'color-swatches.js' | asset_url }}" defer></script>
  <script src="{{ 'image-zoom.js' | asset_url }}" defer></script>
  <script src="{{ 'image-hotspots.js' | asset_url }}" defer></script>
  <script src="{{ 'before-after.js' | asset_url }}" defer></script>
  <script src="{{ 'complete-the-look.js' | asset_url }}" defer></script>
  <script src="{{ 'product-video.js' | asset_url }}" defer></script>
  <script src="{{ 'video-background.js' | asset_url }}" defer></script>
  <script src="{{ 'shoppable-video.js' | asset_url }}" defer></script>
  <script src="{{ 'faq.js' | asset_url }}" defer></script>
  <script src="{{ 'currency-switcher.js' | asset_url }}" defer></script>
</body>
</html>
